# Copy to .env, fill with real values, then: source .env && ./run-app.sh
# .env is gitignored — never commit credentials (§D-002)
export SPRING_DATASOURCE_USERNAME=
export SPRING_DATASOURCE_PASSWORD=
export JWT_SECRET=
export LDAP_URL_TOKEN=https://openapidev1.bankmega.local:15000/realms/bpsecurity/protocol/openid-connect/token
export LDAP_URL_VERIFY_PASSWORD=
export LDAP_CLIENT_ID=
export LDAP_CLIENT_SECRET=
export LDAP_USERNAME=
export LDAP_PASSWORD=
export LDAP_PARTNER_ID=
export LDAP_CHANNEL_ID=
export LDAP_HOST=openapidev1.bankmega.local
export LDAP_AES_KEY=
