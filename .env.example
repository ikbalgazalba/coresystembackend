# Copy to .env, fill the blanks with real values, then run:  ./run-app.sh
# (run-app.sh auto-loads .env; or manually:  set -a; source .env; set +a)
# .env is gitignored — NEVER commit credentials (constitution §D-002).
# Endpoint values below verified against newmojf UAT (openapidev2 / realm quarkus).

# --- Database (newmojf UAT) ---
export SPRING_DATASOURCE_URL=jdbc:postgresql://10.95.1.43:5432/newmojf
export SPRING_DATASOURCE_USERNAME=
export SPRING_DATASOURCE_PASSWORD=

# --- JWT secret (generate one: head -c 96 /dev/urandom | base64 -w0) ---
# Must be Base64, >=64 bytes for HS512. Different per environment.
export JWT_SECRET=

# --- LDAP UCS (newmojf UAT: openapidev2 / realm quarkus) ---
export LDAP_URL_TOKEN=https://openapidev2.bankmega.local:15000/realms/quarkus/protocol/openid-connect/token
export LDAP_URL_VERIFY_PASSWORD=https://openapidev2.bankmega.local:15000/openapi/v1.0/ldap/verifypassword/
export LDAP_HOST=openapidev2.bankmega.local
export LDAP_CLIENT_ID=
export LDAP_CLIENT_SECRET=
export LDAP_USERNAME=
export LDAP_PASSWORD=
export LDAP_PARTNER_ID=
export LDAP_CHANNEL_ID=
export LDAP_AES_KEY=
